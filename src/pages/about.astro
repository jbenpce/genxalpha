---
import Layout from '../layouts/Layout.astro';

// Career waypoints. NOTE: [Placeholder] dates/details to be confirmed by John.
const waypoints = [
  {
    label: 'Wall Street',
    body: 'Started in finance at Goldman Sachs, where the hunt for alpha — returns beyond the market — became a career-long habit.',
  },
  {
    label: 'Energy',
    body: 'Moved into renewable energy and private equity, backing and building projects across the energy transition, including battery storage.',
  },
  {
    label: 'Today',
    body: 'Invests privately across renewables, AI, bitcoin and other frontier themes — and writes about what he learns at genXalpha.',
  },
];
---

<Layout
  title="About — genXalpha"
  description="genXalpha is written by John Bottomley, CFA — investor in energy, AI and bitcoin, formerly of Goldman Sachs."
>
  <section class="section section--dark">
    <div class="container about-hero">
      <p class="eyebrow">About</p>
      <h1>The person behind genXalpha.</h1>
      <p class="lede">
        genXalpha is written by John Bottomley, CFA — an investor and operator
        in the energy transition, with a career that runs from Wall Street to
        renewable-energy private equity.
      </p>
    </div>
  </section>

  <section class="section section--surface">
    <div class="container">
      <p class="eyebrow">Background</p>
      <h2>From alpha to Alpha.</h2>
      <div class="waypoints">
        {waypoints.map((w) => (
          <article class="waypoint">
            <h3>{w.label}</h3>
            <p>{w.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container why">
      <div>
        <p class="eyebrow">Why write</p>
        <h2>Ideas compound too.</h2>
      </div>
      <div class="why__body">
        <p>
          The biggest themes of our time — the energy transition, artificial
          intelligence, sound digital money — cut across every generation, from
          Gen&nbsp;X to Gen&nbsp;Alpha. genXalpha exists to think about them out
          loud: clearly, independently and with skin in the game.
        </p>
        <p>
          Alongside markets and energy, John writes about philosophy and
          human potential — because the best returns of all come from thinking
          well.
        </p>
        <p>
          <a href="https://genxalpha.substack.com" target="_blank" rel="noopener">
            Read and subscribe on Substack&nbsp;↗
          </a>
        </p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .about-hero h1 { max-width: 18ch; }
  .about-hero .lede { margin-top: 1rem; }

  .waypoints {
    margin-top: 3rem;
    display: grid;
    gap: 2.5rem;
    grid-template-columns: repeat(3, 1fr);
  }
  .waypoint { border-top: 2px solid var(--orange); padding-top: 1.5rem; }
  .waypoint h3 { margin-bottom: 0.5rem; }
  .waypoint p { color: var(--muted); margin: 0; }

  .why {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 3rem;
    align-items: start;
  }
  .why__body p:last-child { margin-bottom: 0; }

  @media (max-width: 820px) {
    .waypoints { grid-template-columns: 1fr; gap: 2rem; }
    .why { grid-template-columns: 1fr; gap: 1.5rem; }
  }
</style>
