---
import Layout from '../layouts/Layout.astro';

// The four pillars genXalpha writes about.
const pillars = [
  {
    title: 'Energy & the Grid',
    body: 'Renewable energy, battery storage and the grid infrastructure that will decide how fast the world electrifies — and how AI actually gets powered.',
  },
  {
    title: 'Bitcoin & Money',
    body: 'Bitcoin as the apex asset: sound money, energy-secured settlement, and what it means for wealth across generations.',
  },
  {
    title: 'Markets & Alpha',
    body: 'Macro, central banks and private markets — hunting for asymmetric opportunities the consensus hasn’t priced yet.',
  },
  {
    title: 'Philosophy & Potential',
    body: 'Clear thinking as an edge. Ideas from philosophy applied to investing, work and living well — for every generation.',
  },
];

// Featured essays — link out to Substack, where the writing lives.
const featured = [
  {
    title: 'Why AI’s Future Depends on the Grid, Not the Lab',
    href: 'https://genxalpha.substack.com/p/why-ais-future-depends-on-the-grid',
    tag: 'Energy & AI',
  },
  {
    title: 'Bitcoin: the Apex Asset',
    href: 'https://genxalpha.substack.com/p/bitcoin-the-apex-asset',
    tag: 'Bitcoin',
  },
  {
    title: 'Greenspar.x Powers Up',
    href: 'https://genxalpha.substack.com/p/greensparx-powers-up',
    tag: 'Energy',
  },
];
---

<Layout>
  <!-- Hero -->
  <section class="hero section--dark">
    <div class="container hero__inner">
      <h1 class="hero__wordmark">
        gen<span class="hero__x">X</span>alpha
      </h1>
      <p class="tagline hero__tagline">Unlocking potential across all generations</p>
      <p class="lede hero__lede">
        Ideas on energy, AI, bitcoin, markets and philosophy — from Gen&nbsp;X
        to Gen&nbsp;Alpha, in pursuit of alpha.
      </p>
      <div class="hero__actions">
        <a class="btn btn--solid" href="https://genxalpha.substack.com" target="_blank" rel="noopener">
          Read on Substack
        </a>
        <a class="btn" href="about">About</a>
      </div>
    </div>
  </section>

  <!-- The name -->
  <section class="section section--surface" id="name">
    <div class="container name">
      <div>
        <p class="eyebrow">The name</p>
        <h2>X, Y, Z&hellip; Alpha.</h2>
      </div>
      <div class="name__body">
        <p>
          genXalpha spans the generations — X, Y, Z and Alpha — because the
          forces reshaping our world touch every one of them: the energy
          transition, artificial intelligence, and the emergence of sound
          digital money.
        </p>
        <p>
          And <em>alpha</em> means something else too: the excess return earned
          by seeing what others don't. That hunt — for undervalued ideas,
          assets and potential — is what this project is about.
        </p>
      </div>
    </div>
  </section>

  <!-- Pillars -->
  <section class="section section--dark" id="focus">
    <div class="container">
      <p class="eyebrow">Focus</p>
      <h2>What genXalpha covers.</h2>
      <div class="pillars">
        {pillars.map((p) => (
          <article class="pillar">
            <h3>{p.title}</h3>
            <p>{p.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured writing -->
  <section class="section section--surface" id="writing">
    <div class="container">
      <p class="eyebrow">Writing</p>
      <h2>Recent essays.</h2>
      <ul class="featured">
        {featured.map((f) => (
          <li class="featured__item">
            <a href={f.href} target="_blank" rel="noopener">
              <span class="featured__tag">{f.tag}</span>
              <span class="featured__title">{f.title}</span>
              <span class="featured__arrow" aria-hidden="true">→</span>
            </a>
          </li>
        ))}
      </ul>
      <div class="featured__more">
        <a class="btn" href="writing">All writing</a>
      </div>
    </div>
  </section>

  <!-- Subscribe -->
  <section class="section section--dark" id="subscribe">
    <div class="container subscribe">
      <h2>Never miss an essay.</h2>
      <p class="lede">
        New writing lands on Substack first. Subscribe free and get it in your
        inbox.
      </p>
      <a class="btn btn--solid" href="https://genxalpha.substack.com/subscribe" target="_blank" rel="noopener">
        Subscribe
      </a>
    </div>
  </section>
</Layout>

<style>
  .hero { padding-block: clamp(5rem, 12vw, 9rem); }
  .hero__inner { text-align: center; }
  .hero__wordmark {
    margin: 0;
    font-size: clamp(3rem, 10vw, 6.5rem);
    letter-spacing: -0.02em;
    line-height: 1;
    /* Phase in on load. */
    opacity: 0;
    animation: heroIn 1.6s ease-out 0.15s forwards;
  }
  .hero__x { color: var(--orange); font-weight: 700; }
  .hero__tagline { margin-top: 1.75rem; }
  .hero__lede { margin: clamp(1.5rem, 4vw, 2.25rem) auto 0; }
  .hero__actions {
    margin-top: clamp(2rem, 5vw, 3rem);
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  @keyframes heroIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__wordmark { opacity: 1; animation: none; }
  }

  /* The name */
  .name {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 3rem;
    align-items: start;
  }
  .name__body p:last-child { margin-bottom: 0; }

  /* Pillars */
  .pillars {
    margin-top: 3rem;
    display: grid;
    gap: 2.5rem;
    grid-template-columns: repeat(2, 1fr);
  }
  .pillar { border-top: 2px solid var(--orange); padding-top: 1.5rem; }
  .pillar h3 { margin-bottom: 0.5rem; }
  .pillar p { color: var(--muted); margin: 0; }

  /* Featured writing */
  .featured {
    list-style: none;
    margin: 3rem 0 0;
    padding: 0;
    border-top: 1px solid var(--line-dark);
  }
  .featured__item a {
    display: flex;
    align-items: baseline;
    gap: 1.25rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--line-dark);
    color: var(--paper);
  }
  .featured__item a:hover .featured__title { color: var(--orange); }
  .featured__tag {
    flex: 0 0 8.5rem;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-weight: 600;
    color: var(--orange-dark);
  }
  .featured__title {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 2.4vw, 1.5rem);
    transition: color 0.2s ease;
  }
  .featured__arrow { margin-left: auto; color: var(--muted-dark); }
  .featured__more { margin-top: 2.5rem; }

  /* Subscribe */
  .subscribe { text-align: center; }
  .subscribe .lede { margin-inline: auto; margin-bottom: 2rem; }

  @media (max-width: 820px) {
    .name { grid-template-columns: 1fr; gap: 1.5rem; }
    .pillars { grid-template-columns: 1fr; gap: 2rem; }
    .featured__item a { flex-wrap: wrap; gap: 0.5rem 1.25rem; }
    .featured__tag { flex-basis: 100%; }
  }
</style>
