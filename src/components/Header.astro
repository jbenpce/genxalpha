---
// Base-aware paths so links work both at the root (genxalpha.xyz) and under
// the GitHub Pages sub-path preview. BASE_URL has a trailing slash.
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const withBase = (p: string) => `${base}${p}`.replace(/\/{2,}/g, '/');
const norm = (p: string) => p.replace(/\/+$/, '') || '/';

const path = norm(Astro.url.pathname);
const isActive = (href: string) => norm(href) === path;

const links = [
  { href: withBase(''), label: 'Home' },
  { href: withBase('about'), label: 'About' },
  { href: withBase('writing'), label: 'Writing' },
];
---

<header class="site-header">
  <div class="container site-header__inner">
    <a href={withBase('')} class="brand" aria-label="genXalpha — home">
      gen<span class="brand__x">X</span>alpha
    </a>

    <input type="checkbox" id="nav-toggle" class="nav-toggle" aria-hidden="true" />
    <label for="nav-toggle" class="nav-burger" aria-label="Toggle navigation">
      <span></span><span></span><span></span>
    </label>

    <nav class="site-nav" aria-label="Primary">
      {links.map((l) => (
        <a
          href={l.href}
          class:list={['site-nav__link', { 'is-active': isActive(l.href) }]}
          aria-current={isActive(l.href) ? 'page' : undefined}
        >
          {l.label}
        </a>
      ))}
      <a
        href="https://genxalpha.substack.com"
        class="site-nav__link site-nav__link--external"
        target="_blank"
        rel="noopener"
      >
        Substack ↗
      </a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--ink) 82%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--line);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 4.75rem;
  }
  .brand {
    font-family: var(--font-display);
    font-size: 1.45rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: var(--paper);
  }
  .brand:hover { color: var(--paper); }
  .brand__x {
    color: var(--orange);
    font-weight: 700;
  }

  .site-nav {
    display: flex;
    gap: 2.25rem;
  }
  .site-nav__link {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-weight: 500;
    color: var(--muted);
    padding-block: 0.25rem;
    border-bottom: 1px solid transparent;
  }
  .site-nav__link:hover { color: var(--paper); }
  .site-nav__link.is-active {
    color: var(--paper);
    border-bottom-color: var(--orange);
  }
  .site-nav__link--external { color: var(--orange-dark); }

  /* Mobile menu (CSS-only) */
  .nav-toggle, .nav-burger { display: none; }

  @media (max-width: 720px) {
    .nav-burger {
      display: flex;
      flex-direction: column;
      gap: 5px;
      width: 28px;
      cursor: pointer;
      padding: 6px 0;
    }
    .nav-burger span {
      height: 2px;
      width: 100%;
      background: var(--paper);
      transition: transform 0.25s ease, opacity 0.25s ease;
    }
    .site-nav {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      gap: 0;
      background: var(--ink-2);
      border-bottom: 1px solid var(--line);
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease;
    }
    .site-nav__link {
      padding: 1rem clamp(1.25rem, 5vw, 3rem);
      border-bottom: 1px solid var(--line);
    }
    .nav-toggle:checked ~ .site-nav { max-height: 60vh; }
    .nav-toggle:checked ~ .nav-burger span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .nav-toggle:checked ~ .nav-burger span:nth-child(2) { opacity: 0; }
    .nav-toggle:checked ~ .nav-burger span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
  }
</style>
